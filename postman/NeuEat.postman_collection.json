              "raw": "{\n  \"id\": \"{{driverId}}\",\n  \"phoneNumber\": \"1234567890\"\n}"
            },
            "url": "{{baseUrl}}/api/driver/resetPhone"
          }
        },
        {
          "name": "Driver Reset Address",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
