    {
      "name": "Order",
      "item": [
        {
          "name": "Add To Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"restaurantId\": \"{{restaurantId}}\",\n  \"shopcart\": [\n    {\n      \"dishName\": \"Cheese Pizza\",\n      \"price\": 11.99,\n      \"imageUrl\": \"https://example.com/pizza.jpg\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/order/addToCart"
          }
        },
