{
  "info": {
    "name": "NeuEat API",
    "description": "Postman collection for the Zoomato-CloneApp backend (Spring Boot).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "customerId",
      "value": "customer-id"
    },
    {
      "key": "driverId",
      "value": "driver-id"
    },
    {
      "key": "restaurantId",
      "value": "restaurant-id"
    },
    {
      "key": "orderId",
      "value": "order-id"
    },
    {
      "key": "query",
      "value": "pizza"
    }
  ],
  "item": [
    {
      "name": "Customer",
      "item": [
        {
          "name": "Get Customer By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/customer/{{customerId}}"
          }
        },
        {
          "name": "Customer Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"alice\",\n  \"password\": \"secret\"\n}"
            },
            "url": "{{baseUrl}}/api/customer/login"
          }
        },
        {
          "name": "Customer Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userName\": \"alice\",\n  \"password\": \"secret\",\n  \"phoneNumber\": \"1234567890\",\n  \"address\": \"1 Main St\",\n  \"city\": \"Boston\",\n  \"state\": \"MA\",\n  \"zip\": \"02115\"\n}"
            },
            "url": "{{baseUrl}}/api/customer/register"
          }
        },
        {
          "name": "Customer Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/customer/logout"
          }
        },
        {
          "name": "Get Customer Cart",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/customer/myCart/{{customerId}}"
          }
        },
        {
          "name": "Get Customer Active Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/customer/myActiveOrders/{{customerId}}"
          }
        },
        {
          "name": "Get Customer Order History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/customer/myOrderHistory/{{customerId}}"
          }
        },
        {
          "name": "Delete Customer",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/customer/{{customerId}}"
          }
        },
        {
          "name": "Customer Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{customerId}}\",\n  \"password\": \"old-secret\",\n  \"newPassword\": \"new-secret\"\n}"
            },
            "url": "{{baseUrl}}/api/customer/resetPassword"
          }
        },
        {
          "name": "Customer Reset Phone",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{customerId}}\",\n  \"phoneNumber\": \"1234567890\"\n}"
            },
            "url": "{{baseUrl}}/api/customer/resetPhone"
          }
        },
        {
          "name": "Customer Reset Address",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{customerId}}\",\n  \"address\": \"2 New St\",\n  \"city\": \"Boston\",\n  \"state\": \"MA\",\n  \"zip\": \"02116\"\n}"
            },
            "url": "{{baseUrl}}/api/customer/resetAddress"
          }
        }
      ]
    },
