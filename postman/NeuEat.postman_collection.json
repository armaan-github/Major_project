            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"rating\": 5,\n  \"content\": \"Great food and fast delivery\"\n}"
            },
            "url": "{{baseUrl}}/api/order/addComment"
