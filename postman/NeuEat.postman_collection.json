            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{driverId}}\",\n  \"address\": \"4 New St\",\n  \"city\": \"Boston\",\n  \"state\": \"MA\",\n  \"zip\": \"02120\"\n}"
            },
            "url": "{{baseUrl}}/api/driver/resetAddress"
          }
        }
      ]
