          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/order/{{orderId}}"
          }
        },
        {
          "name": "Checkout All",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orders\": [\n    {\n      \"id\": \"{{orderId}}\"\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/order/checkoutAll"
          }
        },
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
